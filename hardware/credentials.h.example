// 🔹 WiFi (must be 2.4 GHz — ESP8266 does NOT support 5 GHz)
const char* ssid = "YOUR_WIFI_SSID";
const char* password = "YOUR_WIFI_PASSWORD";

// 🔹 Firebase Realtime Database URL (no trailing slash)
// Get this from Firebase Console > Realtime Database > Data tab (URL at top)
const char* firebaseHost = "https://YOUR-PROJECT-ID-default-rtdb.firebaseio.com";
