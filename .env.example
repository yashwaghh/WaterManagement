# ============================================
# AquaSync — Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Firebase Configuration
# Download service_account.json from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./service_account.json
FIREBASE_DATABASE_URL=https://YOUR-PROJECT-ID-default-rtdb.firebaseio.com
FIREBASE_DB_PATH=/readings

# Data Mode: "simulation" | "hybrid" | "firebase"
#   simulation = all flats simulated (no hardware needed)
#   hybrid     = A-101 uses real Firebase data, A-102–A-105 simulated
#   firebase   = all flats read from Firebase (all hardware connected)
DATA_MODE=hybrid

# Water Management
SIMULATED_DAY_LENGTH_SECONDS=60
PER_PERSON_ML=500
DEFAULT_FAMILY_SIZE=4
BOTTLE_CAPACITY_ML=5000
SIMULATED_WEEK_DAYS=7

# Dashboard
POLL_INTERVAL_SECONDS=5

# Admin Authentication
# Generate a strong random string. All /api/admin/* routes require:
#   Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=change-me-to-a-strong-random-secret

# Frontend admin secret (must match ADMIN_SECRET above)
REACT_APP_ADMIN_SECRET=change-me-to-a-strong-random-secret

# SQLite persistence
SQLITE_DB_PATH=./water_management.db
