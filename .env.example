# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./service_account.json
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_DB_PATH=/readings

# System Configuration
DATA_MODE=hybrid
SIMULATED_DAY_LENGTH_SECONDS=60
USAGE_THRESHOLD_ML=2500
BOTTLE_CAPACITY_ML=5000
POLL_INTERVAL_SECONDS=5

# Hybrid Mode Setup
# Edit api.py lines 33-34 to configure which flats use real vs simulated data
# Default: A-101 uses Firebase (real), A-102-A-105 use simulation
